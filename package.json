{
  "name": "x-get2put",
  "version": "0.3.23",
  "private": true,
  "description": "TwitterAPI.io 监控与转发系统（本地测试面板 + 轮询监控）",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:exe": "pkg server.js --config package.json --targets node18-win-x64 --output dist-exe/X-get2put.exe --public",
    "package:exe": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-exe.ps1",
    "release:exe": "npm run build:exe && npm run package:exe",
    "smoke:bulk-config": "node scripts/bulk-config-smoke.mjs",
    "smoke:follow-queue": "node scripts/follow-queue-smoke.mjs",
    "smoke:follow-filter": "node scripts/follow-filter-smoke.mjs",
    "core-test": "node scripts/core-test.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:bulk-core": "playwright test tests/bulk.e2e.spec.js tests/bulk.hot-update.e2e.spec.js",
    "test:e2e:harvest-acceptance": "playwright test tests/harvest.acceptance.spec.js",
    "test:bulk-regression": "npm run smoke:bulk-config && npm run smoke:follow-queue && npm run smoke:follow-filter && npm run test:e2e:bulk-core"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^4.21.2",
    "https-proxy-agent": "^7.0.6",
    "puppeteer-core": "^24.35.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "twitter-api-v2": "^1.28.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "node_modules/puppeteer-extra-plugin-stealth/evasions/**/index.js"
    ],
    "assets": [
      "public/**/*"
    ]
  }
}
